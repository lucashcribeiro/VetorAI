# VETOR — variáveis de ambiente
# Copie para .env.local e preencha com valores reais.

# URL canônica do site (SEO: sitemap, Open Graph, metadataBase)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Postgres (Neon ou local)
DATABASE_URL="postgresql://user:password@host/vetor?sslmode=require"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET="cole-um-segredo-longo-aqui"
# AUTH_URL="http://localhost:3000"  # opcional em dev

# Seed (opcional)
# SEED_ADMIN_EMAIL="admin@vetor.local"
# SEED_ADMIN_PASSWORD="vetor-admin-2026"

# Anthropic (relatórios e Zelo)
ANTHROPIC_API_KEY="sk-ant-..."

# Câmbio usado para registrar custo de IA em BRL
USD_BRL="5.5"

# Trigger.dev (opcional — sem isso o job de relatório roda via after())
# TRIGGER_SECRET_KEY="tr_dev_..."
# TRIGGER_PROJECT_REF="proj_..."

# Cobrança manual (Fase 7) — opcional
# VETOR_PIX_CHAVE="sua-chave-pix"
# VETOR_PIX_TITULAR="VETOR Consultoria"
# VETOR_PLANO_ESSENCIAL_BRL="497"
# VETOR_PLANO_COMPLETO_BRL="997"

# WhatsApp Cloud API (Zelo — opcional; sem token o envio é simulado)
WHATSAPP_VERIFY_TOKEN="vetor-zelo-dev"
# WHATSAPP_APP_SECRET="..."
# WHATSAPP_ACCESS_TOKEN="EAA..."
# WHATSAPP_PHONE_NUMBER_ID="..."

# OpenAI (alternativa temporária à Anthropic — prioridade se ambas existirem)
# OPENAI_API_KEY="sk-proj-..."
