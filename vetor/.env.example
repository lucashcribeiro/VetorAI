# VETOR — variáveis de ambiente
# Copie para .env.local e preencha com valores reais.

# Postgres (Neon) — string de conexão do painel do Neon
DATABASE_URL="postgresql://user:password@host/vetor?sslmode=require"

# Clerk (dashboard.clerk.com → API Keys). Organizations precisa estar habilitado.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Webhook (dashboard → Webhooks → endpoint /api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Anthropic (obrigatória para gerar relatórios na Fase 2)
ANTHROPIC_API_KEY="sk-ant-..."

# Câmbio usado para registrar custo de IA em BRL
USD_BRL="5.5"

# Trigger.dev (opcional na Fase 2 — sem isso o job roda via after() do Next.js)
TRIGGER_SECRET_KEY="tr_dev_..."
TRIGGER_PROJECT_REF="proj_..."

# Vercel Blob (opcional — sem token o HTML fica no banco e baixa por /api/relatorios/:id/download)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."
