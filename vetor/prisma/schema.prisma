// VETOR — schema multi-tenant (core + módulos).
// Regra: toda tabela operacional tem tenant_id; o filtro é injetado
// automaticamente pela extensão em core/db/client.ts (ADR-003).

generator client {
  provider = "prisma-client"
  output   = "../core/db/generated"
}

datasource db {
  provider = "postgresql"
}

// A empresa cliente. Isolamento total de dados por tenant.
model Tenant {
  id          String   @id @default(cuid())
  nome        String
  slug        String   @unique
  segmento    String?
  logoUrl     String?  @map("logo_url")
  corPrimaria String?  @map("cor_primaria")
  plano       String   @default("essencial")
  status      String   @default("ativo")
  criadoEm    DateTime @default(now()) @map("criado_em")

  modules     TenantModule[]
  memberships Membership[]
  atividades  ActivityLog[]
  eventos     Event[]
  usosDeIa    AiUsage[]
  dossies     Dossie[]
  agentRuns   AgentRun[]
  relatorios  RelatorioGerado[]
  zeloConversas ZeloConversa[]
  zeloMensagens ZeloMensagem[]
  conteudoPosts ConteudoPost[]
  midiaMetricas MidiaMetrica[]
  midiaAlertas  MidiaAlerta[]
  timeEntregas  TimeEntrega[]
  timeRodadas   TimeRodada[]

  @@map("tenants")
}

// Feature flags + nível de autonomia por módulo (config jsonb).
model TenantModule {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  moduleId String  @map("module_id")
  ativo    Boolean @default(false)
  config   Json    @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
}

// Usuário da plataforma (Auth.js — credenciais no próprio banco).
// role: MEMBER | SUPER_ADMIN (SUPER_ADMIN = operador VETOR, cross-tenant admin).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nome         String
  passwordHash String   @map("password_hash")
  role         String   @default("MEMBER") // MEMBER | SUPER_ADMIN
  criadoEm     DateTime @default(now()) @map("criado_em")

  memberships Membership[]

  @@map("users")
}

model Membership {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")
  papel    String @default("MEMBER") // OWNER | MEMBER

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("memberships")
}

// Trilha de auditoria: quem aprovou o quê, com data e hora.
model ActivityLog {
  id       String   @id @default(cuid())
  tenantId String   @map("tenant_id")
  userId   String?  @map("user_id")
  acao     String
  detalhe  Json     @default("{}")
  criadoEm DateTime @default(now()) @map("criado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, criadoEm])
  @@map("activity_log")
}

// Comunicação entre módulos (ADR-002): publica aqui, o outro consome.
model Event {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tipo       String
  payload    Json     @default("{}")
  processado Boolean  @default(false)
  criadoEm   DateTime @default(now()) @map("criado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([processado, tipo])
  @@index([tenantId, criadoEm])
  @@map("events")
}

// Margem real por cliente: tokens e custo de cada chamada de IA.
model AiUsage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  moduleId  String   @map("module_id")
  modelo    String
  tokensIn  Int      @map("tokens_in")
  tokensOut Int      @map("tokens_out")
  custoBrl  Decimal  @map("custo_brl") @db.Decimal(10, 4)
  criadoEm  DateTime @default(now()) @map("criado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, criadoEm])
  @@map("ai_usage")
}

// Dossiê do Cliente — contexto compartilhado de todos os agentes.
model Dossie {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  versao       Int      @default(1)
  conteudo     Json     @default("{}")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, versao])
  @@map("dossies")
}

// Execuções dos agentes (kick off, mídia, criativos, ...).
model AgentRun {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  agente      String
  status      String    @default("rodando") // rodando | concluido | erro
  iniciadoEm  DateTime  @default(now()) @map("iniciado_em")
  terminadoEm DateTime? @map("terminado_em")
  erro        String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, iniciadoEm])
  @@map("agent_runs")
}

// ── modules/relatorios ────────────────────────────────────────────
// Relatório mensal em linguagem de dono (Fase 2).
// Status: processando | pronto | erro
model RelatorioGerado {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  mes          String // YYYY-MM
  status       String   @default("processando")
  dadosEntrada Json     @default("{}") @map("dados_entrada")
  conteudoHtml String?  @map("conteudo_html") @db.Text
  arquivoUrl   String?  @map("arquivo_url")
  resumo       String?
  erro         String?
  criadoPorId  String?  @map("criado_por_id")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, mes])
  @@index([tenantId, criadoEm])
  @@map("relatorios_gerados")
}

// ── modules/conteudo ──────────────────────────────────────────────
// Calendário semanal + fila de aprovação (Fase 5).
// Status: gerando | pendente | aprovado | rejeitado | exportado | erro
model ConteudoPost {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  semanaInicio  String    @map("semana_inicio") // YYYY-MM-DD (segunda)
  canal         String    @default("instagram")
  titulo        String?
  texto         String    @db.Text
  hashtags      String?
  status        String    @default("pendente")
  agendadoPara  DateTime? @map("agendado_para")
  ordem         Int       @default(0)
  aprovadoPorId String?   @map("aprovado_por_id")
  aprovadoEm    DateTime? @map("aprovado_em")
  exportadoEm   DateTime? @map("exportado_em")
  erro          String?
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, semanaInicio])
  @@index([tenantId, status])
  @@map("conteudo_posts")
}

// ── modules/midia ─────────────────────────────────────────────────
// Monitor de anúncios (Fase 6): CSV → histórico → alertas.
// Etapa B (Meta API) grava nas mesmas tabelas com origem = "api".
model MidiaMetrica {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  data       DateTime @db.Date
  campanha   String
  plataforma String   @default("meta") // meta | google | outro
  gasto      Decimal  @db.Decimal(12, 2)
  impressoes Int      @default(0)
  cliques    Int      @default(0)
  leads      Int      @default(0)
  conversoes Int      @default(0)
  // Custo por lead/contato (língua de dono: "quanto custa trazer alguém")
  cpl        Decimal? @db.Decimal(12, 2)
  origem     String   @default("csv") // csv | api
  criadoEm   DateTime @default(now()) @map("criado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, data])
  @@index([tenantId, campanha, data])
  @@map("midia_metricas")
}

// Status: aberto | resolvido | ignorado
model MidiaAlerta {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  campanha      String
  tipo          String // cpl_subiu | gasto_alto | sem_resultado
  severidade    String    @default("atencao") // info | atencao | critico
  mensagem      String    @db.Text
  valorAtual    Decimal?  @map("valor_atual") @db.Decimal(12, 2)
  valorBaseline Decimal?  @map("valor_baseline") @db.Decimal(12, 2)
  status        String    @default("aberto")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  resolvidoEm   DateTime? @map("resolvido_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, criadoEm])
  @@map("midia_alertas")
}

// ── modules/time (Time VETOR) ─────────────────────────────────────
// Pipeline automática: Órbita → Atlas → Lumen → Mídia → Prisma (QA).
// Rodada = uma estruturação completa a partir de um brief.
model TimeRodada {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  brief        String   @db.Text
  status       String   @default("rodando") // rodando | qa | retrabalho | concluido | erro
  etapaAtual   String   @default("orquestrador") @map("etapa_atual")
  log          Json     @default("[]") // trilha de etapas
  tentativasQa Int      @default(0) @map("tentativas_qa")
  erro         String?
  criadoPorId  String?  @map("criado_por_id")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entregas TimeEntrega[]

  @@index([tenantId, criadoEm])
  @@index([tenantId, status])
  @@map("time_rodadas")
}

// Entregáveis dos funcionários (por rodada).
// status: rascunho | aprovado | rejeitado_qa
model TimeEntrega {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  rodadaId    String?  @map("rodada_id")
  agente      String // orquestrador | estrategista | copywriter | gestor_midia | analista_bi
  tipo        String // mapa-de-nicho | plano-gtm | copy-ads | estrutura-campanha | relatorio-mensal | sumario | plano-trabalho | qa
  titulo      String?
  conteudo    String   @db.Text
  brief       String?  @db.Text
  status      String   @default("rascunho")
  versao      Int      @default(1)
  agentRunId  String?  @map("agent_run_id")
  criadoPorId String?  @map("criado_por_id")
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rodada TimeRodada? @relation(fields: [rodadaId], references: [id], onDelete: Cascade)

  @@index([tenantId, agente, criadoEm])
  @@index([tenantId, status])
  @@index([rodadaId])
  @@map("time_entregas")
}

// Leads do site público (sem tenant — validação de demanda / diagnóstico).
model Lead {
  id       String   @id @default(cuid())
  nome     String?
  email    String
  telefone String?
  empresa  String?
  origem   String // diagnostico | ferramenta | contato
  moduleId String?  @map("module_id")
  mensagem String?  @db.Text
  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([criadoEm])
  @@index([origem, moduleId])
  @@map("leads")
}

// ── modules/zelo ──────────────────────────────────────────────────
// Recepcionista assistida no WhatsApp (Fase 3 v1).
// Status conversa: aguardando | respondida | escalada
// Direção mensagem: entrada | saida | sugestao
model ZeloConversa {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  waId                  String    @map("wa_id") // telefone E.164 sem +
  nomeContato           String?   @map("nome_contato")
  status                String    @default("aguardando")
  primeiraMsgEm         DateTime  @map("primeira_msg_em")
  ultimaMsgEm           DateTime  @map("ultima_msg_em")
  primeiraRespostaEm    DateTime? @map("primeira_resposta_em")
  tempoPrimeiraRespostaMs Int?    @map("tempo_primeira_resposta_ms")
  criadoEm              DateTime  @default(now()) @map("criado_em")
  atualizadoEm          DateTime  @updatedAt @map("atualizado_em")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mensagens ZeloMensagem[]

  @@unique([tenantId, waId])
  @@index([tenantId, status, ultimaMsgEm])
  @@map("zelo_conversas")
}

model ZeloMensagem {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  conversaId   String   @map("conversa_id")
  direcao      String // entrada | saida | sugestao
  corpo        String   @db.Text
  waMessageId  String?  @unique @map("wa_message_id")
  status       String   @default("recebida") // recebida | pendente | aprovada | descartada | enviada | erro
  aprovadaPorId String? @map("aprovada_por_id")
  criadoEm     DateTime @default(now()) @map("criado_em")

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversa ZeloConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversaId, criadoEm])
  @@index([tenantId, status])
  @@map("zelo_mensagens")
}
